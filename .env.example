# ============================================================
# SmartFactory Hub — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values before running
# docker compose up.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it is in .gitignore.
# ============================================================

# ------------------------------------------------------------
# SQL Server
# Password must be ≥8 chars and include:
#   uppercase, lowercase, digit, and a special character.
# ------------------------------------------------------------
SA_PASSWORD=CHANGE_ME_StrongPassword1!

# ------------------------------------------------------------
# RabbitMQ
# Change from the default guest/guest for any non-local env.
# ------------------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASS=CHANGE_ME_RabbitPassword!

# ------------------------------------------------------------
# JWT Signing Key (Identity.API)
# Must be ≥32 characters. Rotate immediately if ever exposed.
# ------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_MinimumOf32CharactersLong!!

# ------------------------------------------------------------
# Grafana
# ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GrafanaPassword!

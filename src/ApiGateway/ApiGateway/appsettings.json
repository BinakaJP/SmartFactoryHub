{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "equipment-route": {
        "ClusterId": "equipment-cluster",
        "Match": {
          "Path": "/api/equipment/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/Equipment/{**catch-all}" }
        ]
      },
      "metrics-route": {
        "ClusterId": "metrics-cluster",
        "Match": {
          "Path": "/api/metrics/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/Metrics/{**catch-all}" }
        ]
      },
      "alerts-route": {
        "ClusterId": "alert-cluster",
        "Match": {
          "Path": "/api/alerts/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/Alerts/{**catch-all}" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/Notifications/{**catch-all}" }
        ]
      },
      "signalr-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/Analytics/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "equipment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://equipment-api:8080"
          }
        }
      },
      "metrics-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://metrics-api:8080"
          }
        }
      },
      "alert-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://alert-api:8080"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://notification-api:8080"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity-api:8080"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://analytics-api:8080"
          }
        }
      }
    }
  }
}
